# ============================================================
# music-stories — .env
# Skopiuj ten plik do .env i uzupełnij wartości
# NIGDY nie commituj .env do gita
# ============================================================

# MongoDB Atlas connection string
MONGO_URL=mongodb+srv://USERNAME:PASSWORD@cluster0.mwnam.mongodb.net/storage?retryWrites=true&w=majority

# Session secret — wygeneruj losowy długi string, np:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=wpisz_tutaj_losowy_dlugiy_string_min_32_znaki

# Google OAuth2 — z Google Cloud Console
GOOGLE_CLIENT_ID=twoj-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=twoj-client-secret

# Callback URL — lokalnie zostawiamy puste (używa /auth/google/callback)
# Na produkcji (Render) ustaw pełny URL:
GOOGLE_CALLBACK_URL=https://music-stories.onrender.com/auth/google/callback

# Środowisko
NODE_ENV=development
