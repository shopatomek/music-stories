# ================================================================
# music-stories — Environment Variables
# ================================================================
# 1. Copy this file:   cp .env.example .env
# 2. Fill in values    (see README.md for how to obtain each one)
# 3. Never commit .env to version control
# ================================================================


# ----------------------------------------------------------------
# MongoDB Atlas
# Get from: cloud.mongodb.com → Connect → Drivers → Node.js
# Replace <username>, <password>, and <cluster> with your values
#
# Standard (Linux / macOS / Render):
# ----------------------------------------------------------------
MONGO_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/musicstories?retryWrites=true&w=majority

# ----------------------------------------------------------------
# Windows / Node.js v18+ workaround — if you get:
#   "querySrv ECONNREFUSED _mongodb._tcp.<cluster>.mongodb.net"
#
# Comment out the line above and uncomment the line below.
# Replace shard hostnames with your actual values — find them in
# Atlas → Connect → Shell (direct connection string).
# ----------------------------------------------------------------
# MONGO_URL=mongodb://<username>:<password>@cluster0-shard-00-00.<cluster>.mongodb.net:27017,cluster0-shard-00-01.<cluster>.mongodb.net:27017,cluster0-shard-00-02.<cluster>.mongodb.net:27017/musicstories?authSource=admin&retryWrites=true&w=majority&tls=true


# ----------------------------------------------------------------
# Session Secret
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ----------------------------------------------------------------
SESSION_SECRET=replace_with_random_string_minimum_32_characters


# ----------------------------------------------------------------
# Google OAuth 2.0
# Get from: console.cloud.google.com → APIs & Services → Credentials
# ----------------------------------------------------------------
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret


# ----------------------------------------------------------------
# OAuth Callback URL
# Local:      http://localhost:5000/auth/google/callback
# Production: https://your-app.onrender.com/auth/google/callback
# ----------------------------------------------------------------
GOOGLE_CALLBACK_URL=http://localhost:5000/auth/google/callback


# ----------------------------------------------------------------
# Environment
# ----------------------------------------------------------------
NODE_ENV=development
